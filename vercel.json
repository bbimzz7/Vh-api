{
  "rewrites": [
    { "source": "/api/getkey",   "destination": "/api/getkey" },
    { "source": "/api/checkkey", "destination": "/api/checkkey" },
    { "source": "/api/token",    "destination": "/api/token" },
    { "source": "/api/dashboard","destination": "/api/dashboard" },
    { "source": "/getkey",       "destination": "/getkey/index.html" },
    { "source": "/getkey/(.*)",  "destination": "/getkey/index.html" },
    { "source": "/dashboard",    "destination": "/dashboard/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard/index.html" }
  ]
}
